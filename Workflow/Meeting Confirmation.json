      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = ($json.text || $json.snippet || \"\").toLowerCase()\n\nlet choice = null\nconst match = text.match(/slot\\s*(\\d)/)\n\nif (match) {\n  choice = Number(match[1])\n}\n\n// 🔥 SUPER SAFE sender extraction (handles ALL cases)\nlet sender = \"unknown\"\n\n// Case 1: Simplified mode\nif ($json.From) {\n  const match = $json.From.match(/<(.+?)>/)\n  sender = match ? match[1] : $json.From\n}\n\n// Case 2: Parsed email format\nelse if ($json.from?.text) {\n  const match = $json.from.text.match(/<(.+?)>/)\n  sender = match ? match[1] : $json.from.text\n}\n\n// Case 3: Raw Gmail payload (attachments ON case)\nelse if ($json.payload?.headers) {\n  const fromHeader = $json.payload.headers.find(h => h.name === \"From\")\n  if (fromHeader) {\n    const match = fromHeader.value.match(/<(.+?)>/)\n    sender = match ? match[1] : fromHeader.value\n  }const text = ($json.snippet || \"\").toLowerCase()\n\nconst match = text.match(/slot\\s*(\\d)/)\nconst choice = match ? Number(match[1]) : null\n\n// extract sender from snippet\nlet sender = \"unknown\"\nconst emailMatch = ($json.snippet || \"\").match(/<(.+?)>/)\nif (emailMatch) sender = emailMatch[1]\n\nreturn {\n  json: {\n    sender,\n    choice\n  }\n}\n}\n\nreturn {\n  json: {\n    choice,\n    sender\n  }\n}"
      },
