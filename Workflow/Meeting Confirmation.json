      "parameters": {
        "jsCode": "let selectedSlot = null\n\nif ($json.choice === 1) selectedSlot = $json.slot1\nif ($json.choice === 2) selectedSlot = $json.slot2\nif ($json.choice === 3) selectedSlot = $json.slot3\nif ($json.choice === 4) selectedSlot = $json.slot4\n\nif (selectedSlot) {\n  selectedSlot = new Date(selectedSlot).toISOString()\n}\n\nreturn {\n  json: {\n    ...$json,\n    selectedSlot\n  }\n}"
      },
