    {
      "parameters": {
        "jsCode": "const selectedSlot = $json.selectedSlot\n\nconst events = $input.all()\n\n// get all booked slots\nconst bookedSlots = events\n  .map(e => e.json.start?.dateTime)\n  .filter(Boolean)\n  .map(t => new Date(t).getTime())\n\n// check selected slot\nconst hasEvents = bookedSlots.includes(\n  new Date(selectedSlot).getTime()\n)\n\n// all slots from DB\nconst slots = [\n  $json.slot1,\n  $json.slot2,\n  $json.slot3,\n  $json.slot4\n]\n\n// filter available slots\nconst availableSlots = slots.filter(slot => {\n  const time = new Date(slot).getTime()\n  return !bookedSlots.includes(time)\n})\n\nreturn [\n  {\n    json: {\n      ...$json,\n      hasEvents,\n      availableSlots\n    }\n  }\n]"
      },
